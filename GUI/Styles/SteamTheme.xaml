<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <!-- Hintergrund -->
    <SolidColorBrush x:Key="SteamBackground"
                     Color="#171A21"/>

    <SolidColorBrush x:Key="SteamPanel"
                     Color="#1B2838"/>


    <!-- Text -->
    <SolidColorBrush x:Key="SteamText"
                     Color="White"/>


    <SolidColorBrush x:Key="SteamSecondaryText"
                     Color="#AAAAAA"/>


    <!-- Button Style -->
    <Style TargetType="Button">

        <Setter Property="Background"
                Value="#1A9FFF"/>

        <Setter Property="Foreground"
                Value="White"/>

        <Setter Property="Padding"
                Value="10"/>

        <Setter Property="Margin"
                Value="5"/>

        <Setter Property="BorderThickness"
                Value="0"/>

    </Style>


    <!-- TextBox Style -->
    <Style TargetType="TextBox">

        <Setter Property="Background"
                Value="#202020"/>

        <Setter Property="Foreground"
                Value="White"/>

        <Setter Property="Padding"
                Value="8"/>

    </Style>


    <!-- DataGrid Style -->
    <Style TargetType="DataGrid">

        <Setter Property="Background"
                Value="#171A21"/>

        <Setter Property="Foreground"
                Value="White"/>

        <Setter Property="GridLinesVisibility"
                Value="None"/>

    </Style>


</ResourceDictionary>