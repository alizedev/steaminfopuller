<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Steam Info Puller"
    Width="900"
    Height="600"
    Background="#171a21">

<Grid Margin="20">

<Grid.RowDefinitions>
<RowDefinition Height="Auto"/>
<RowDefinition Height="Auto"/>
<RowDefinition Height="*"/>
</Grid.RowDefinitions>


<StackPanel Orientation="Horizontal">

<TextBox Width="300"
         Height="30"
         Text="{Binding SteamId}"/>

<Button Margin="10,0"
        Width="120"
        Content="Laden"
        Command="{Binding LoadCommand}"/>

</StackPanel>


<Border Grid.Row="1"
        Margin="0,20"
        Background="#1b2838"
        Padding="20">

<StackPanel>

<TextBlock Text="{Binding Username}"
           FontSize="24"
           Foreground="White"/>

<TextBlock Text="{Binding Status}"
           Foreground="LightGray"/>

</StackPanel>

</Border>


<DataGrid Grid.Row="2"
          ItemsSource="{Binding Games}"
          Background="#202020"
          Foreground="White">

</DataGrid>


</Grid>

</Window>